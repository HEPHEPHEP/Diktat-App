# =============================================================================
# Diktat-App — Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# ACHTUNG: Niemals .env in Git committen!
# =============================================================================

# --- Server ---
# JWT-Secret für Session-Tokens (min. 32 Zeichen, zufällig generieren)
# Beispiel: openssl rand -base64 48
JWT_SECRET=

# Admin-Passwort für den initialen Admin-Account (min. 12 Zeichen)
ADMIN_PASSWORD=

# Server-ID (eindeutig pro Installation)
SERVER_ID=server-001

# Erlaubte Origins für CORS (kommagetrennt)
# Beispiel: http://localhost:8081,http://localhost:8082,https://diktat.meinefirma.de
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082

# --- License Server ---
# API-Secret für die Kommunikation zwischen Server und License-Server (min. 32 Zeichen)
# Beispiel: openssl rand -base64 48
LICENSE_API_SECRET=
